# === Planungshelfer / todo.z-b.tech — Server-Konfiguration ===
# Diese Datei auf dem Server nach .env kopieren und Werte einsetzen.
# NIE ins Git committen. Werte mit Leerzeichen/Sonderzeichen in "Quotes".

# Login-Passwort fuer die Weboberflaeche (nur du). Login ist AN, sobald gesetzt.
PLANUNG_PASSWORD="hier-dein-passwort"

# API-Token fuer Machine-to-Machine (andere Projekte -> POST /api/ingest).
# Erzeugen z.B.:  python3 -c "import secrets; print(secrets.token_hex(24))"
PLANUNG_API_TOKEN="hier-langer-zufalls-token"

# Session-Secret (Cookies). Erzeugen:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
PLANUNG_SECRET="hier-64-hex-zeichen"

# Datenbank ausserhalb vom Repo (bleibt bei Deploys erhalten)
PLANUNG_DB="/home/xahizivi/apps/todo_data/planung.db"

# Hinter HTTPS-Reverse-Proxy: Session-Cookie nur ueber HTTPS
HTTPS_ONLY=1

# gunicorn
BIND="127.0.0.1:8030"
WORKERS=2
